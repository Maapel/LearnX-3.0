# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search API
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: SerpAPI fallback
SERPAPI_KEY=your_serpapi_key_here

# Cloudflare Browser Rendering (optional — better scraping with JS rendering)
# Get these from https://dash.cloudflare.com → API Tokens (need "Browser Rendering - Edit" permission)
CF_ACCOUNT_ID=your_cf_account_id_here
CF_API_TOKEN=your_cf_api_token_here

# Ollama (local fallback — no rate limits, no API key required)
# Run: ollama serve  |  Pull a model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
